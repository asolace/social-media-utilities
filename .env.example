# Server-side only — never prefix with VITE_ (that would expose the key in the client bundle).
# Read by the serverless functions in api/ via process.env.

# Set your Anthropic API key here
ANTHROPIC_API_KEY=your-api-key-here

# Set your Google Gemini API key here (used for AI transcription of YouTube videos without captions)
GEMINI_API_KEY=your-gemini-api-key-here
